wget -O sample_app.apk "https://github.com/OWASP/MSTG-Hacking-Playground/raw/master/Android/MSTG-Android-Java-App/app/build/outputs/apk/debug/app-debug.apk"

# Verify APK file
file sample_app.apk
ls -lh sample_app.apk
