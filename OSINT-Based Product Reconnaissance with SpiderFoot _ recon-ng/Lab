Task 1: Install and Configure OSINT Tools
Step 1.1: Update System and Install Dependencies
# Update system packages
sudo apt update && sudo apt upgrade -y

# Install required packages
sudo apt install -y python3 python3-pip git curl wget build-essential \
    python3-dev libxml2-dev libxslt1-dev zlib1g-dev libffi-dev libssl-dev

# Verify installations
python3 --version
pip3 --version
Step 1.2: Install SpiderFoot
# Create working directory
mkdir ~/osint-lab && cd ~/osint-lab

# Clone SpiderFoot repository
git clone https://github.com/smicallef/spiderfoot.git
cd spiderfoot

# Install dependencies
pip3 install -r requirements.txt

# Test installation
python3 sf.py --help
Step 1.3: Install recon-ng
# Navigate to working directory
cd ~/osint-lab

# Clone recon-ng repository
git clone https://github.com/lanmaster53/recon-ng.git
cd recon-ng

# Install dependencies
pip3 install -r REQUIREMENTS

# Test installation
python3 recon-ng --help
Step 1.4: Start SpiderFoot Web Interface
# Start SpiderFoot server
cd ~/osint-lab/spiderfoot
python3 sf.py -l 127.0.0.1:5001 &

# Verify it's running
sleep 5
curl -s http://127.0.0.1:5001 > /dev/null && echo "SpiderFoot running" || echo "Failed to start"
